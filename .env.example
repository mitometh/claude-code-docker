# Copy to `.env` and edit. `run.sh` and docker-compose both read this file.

# ---- Paths ----
# Where subscription login is persisted on the host.
CLAUDE_DOCKER_AUTH_DIR=$HOME/.claude-docker-auth
# Project folder mounted as /workspace (compose only; run.sh uses its CLI arg).
WORKSPACE=./workspace

# ---- Optional language/tool layers (set to 1 to enable) ----
WITH_GO=1
WITH_PYTHON=1
WITH_RUST=0
WITH_BUILD_ESSENTIAL=0

# Space-separated extra apt packages, e.g. "postgresql-client redis-tools"
EXTRA_APT_PACKAGES=

# Pin a specific Claude Code version, or leave as "latest".
CLAUDE_VERSION=2.1.90
